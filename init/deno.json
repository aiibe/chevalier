{
  "name": "@chevalier/init",
  "version": "0.0.9",
  "license": "MIT",
  "exports": "./mod.ts",
  "publish": {
    "include": ["mod.ts", "templates.gen.ts", "README.md"]
  },
  "imports": {
    "@std/encoding/base64": "jsr:@std/encoding@^1/base64"
  },
  "tasks": {
    "start": "deno run -A mod.ts",
    "gen": "deno run -A scripts/gen-templates.ts",
    "gen:check": "deno run -A scripts/gen-templates.ts --check",
    "smoke": "deno run -A scripts/smoke.ts"
  }
}
