{
  "tasks": {
    "dev": "vite",
    "build": "vite build && vite build --ssr",
    "preview": "vite preview",
    "check:hydration": "deno task build && deno run -A scripts/hydration-check.ts"
  },
  "imports": {
    "chevalier": "../../src/mod.ts",
    "chevalier/registry": "../../src/registry.tsx",
    "chevalier/testing": "../../src/testing.ts",
    "chevalier/vite": "../../src/vite-config.ts",
    "@astral/astral": "jsr:@astral/astral@^0.5.2",
    "@std/http": "jsr:@std/http@^1",
    "@std/path": "jsr:@std/path@^1",
    "hono": "npm:hono@^4.6.0",
    "preact": "npm:preact@^10.24.0",
    "preact/": "npm:/preact@^10.24.0/",
    "preact-render-to-string": "npm:preact-render-to-string@^6.5.0",
    "vite": "npm:vite@^8.0.0",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@prefresh/vite": "npm:@prefresh/vite@^2.4.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.0.0",
    "tailwindcss": "npm:tailwindcss@^4.0.0"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["dom", "dom.iterable", "deno.ns", "esnext"]
  }
}
