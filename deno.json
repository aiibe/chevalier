{
  "name": "@chevalier/core",
  "version": "0.2.1",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts",
    "./client": "./src/client.ts",
    "./registry": "./src/registry.tsx",
    "./static": "./src/static.ts",
    "./testing": "./src/testing.ts",
    "./vite": "./src/vite-config.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "deno.json",
      "assets/chevalier.png"
    ],
    "exclude": [
      "src/**/*.test.ts",
      "src/**/*.test.tsx",
      "src/testdata/",
      "examples/"
    ]
  },
  "tasks": {
    "test": "deno test -A",
    "dev": "vite",
    "build": "vite build && vite build --ssr",
    "preview": "vite preview",
    "demo": "cd examples/basic && deno task dev"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/http": "jsr:@std/http@^1",
    "@std/path": "jsr:@std/path@^1",
    "hono": "npm:hono@^4.6.0",
    "hono/": "npm:/hono@^4.6.0/",
    "preact": "npm:preact@^10.24.0",
    "preact/": "npm:/preact@^10.24.0/",
    "preact-render-to-string": "npm:preact-render-to-string@^6.5.0",
    "vite": "npm:vite@^8.0.0",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@prefresh/vite": "npm:@prefresh/vite@^3.0.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.0.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["dom", "dom.iterable", "deno.ns", "esnext"]
  }
}
